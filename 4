#include <iostream>
#include <vector>
#include <algorithm>

using namespace std;

int main()
{
    vector<int> numbers =
    {
        1,2,3,4,5,6,7,8
    };

    vector<int> evenNumbers;

    copy_if(
        numbers.begin(),
        numbers.end(),
        back_inserter(evenNumbers),
        [](int x)
        {
            return x % 2 == 0;
        });

    vector<int> squaredNumbers;

    transform(
        evenNumbers.begin(),
        evenNumbers.end(),
        back_inserter(squaredNumbers),
        [](int x)
        {
            return x * x;
        });

    cout << "Результат: ";

    for (int x : squaredNumbers)
    {
        cout << x << " ";
    }

    return 0;
}
